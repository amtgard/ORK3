<style>
.emp-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:10100; align-items:center; justify-content:center; }
.emp-overlay.emp-open { display:flex; }
.emp-modal { background:#fff; border-radius:12px; padding:28px 28px 22px; max-width:440px; width:92%; box-shadow:0 8px 40px rgba(0,0,0,0.28); font-family:inherit; }
.emp-header { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
.emp-header-icon { font-size:26px; color:#4299e1; flex-shrink:0; }
.emp-title { font-size:17px; font-weight:700; color:#2d3748; background:transparent; border:none; padding:0; border-radius:0; text-shadow:none; margin:0; }
.emp-body { font-size:13px; color:#4a5568; line-height:1.6; margin-bottom:14px; }
.emp-field { margin-bottom:12px; }
.emp-field label { display:block; font-size:12px; font-weight:600; color:#4a5568; margin-bottom:4px; }
.emp-field input[type="email"] { width:100%; box-sizing:border-box; padding:8px 10px; border:1px solid #e2e8f0; border-radius:5px; font-size:14px; color:#2d3748; }
.emp-field input[type="email"]:focus { outline:none; border-color:#4299e1; box-shadow:0 0 0 3px rgba(66,153,225,.15); }
.emp-error { display:none; color:#e53e3e; font-size:12px; margin-top:4px; }
.emp-actions { display:flex; justify-content:flex-end; align-items:center; gap:10px; margin-top:4px; }
.emp-skip { background:none; border:none; color:#a0aec0; font-size:13px; cursor:pointer; padding:4px 8px; }
.emp-skip:hover { color:#718096; }
.emp-save { background:#4299e1; color:#fff; border:none; border-radius:6px; padding:9px 22px; font-size:14px; font-weight:600; cursor:pointer; transition:background .15s; }
.emp-save:hover:not(:disabled) { background:#2b6cb0; }
.emp-save:disabled { opacity:.6; cursor:not-allowed; }
.emp-suggestion { display:none; align-items:center; gap:8px; margin-top:6px; padding:7px 10px; background:#ebf8ff; border:1px solid #bee3f8; border-radius:5px; font-size:12px; color:#2b6cb0; line-height:1.4; }
.emp-suggestion.emp-suggestion-visible { display:flex; }
.emp-suggestion i { flex-shrink:0; color:#4299e1; }
.emp-suggestion-text { flex:1; }
.emp-suggestion strong { font-weight:700; }
.emp-suggestion-use { background:#4299e1; color:#fff; border:none; padding:3px 9px; border-radius:4px; font-size:11px; font-weight:600; cursor:pointer; white-space:nowrap; }
.emp-suggestion-use:hover { background:#2b6cb0; }
.emp-suggestion-dismiss { background:none; border:none; color:#90cdf4; font-size:16px; line-height:1; cursor:pointer; padding:0 2px; flex-shrink:0; }
.emp-suggestion-dismiss:hover { color:#4299e1; }
</style>
<div class="emp-overlay" id="emp-overlay">
  <div class="emp-modal" role="dialog" aria-modal="true" aria-labelledby="emp-title">
    <div class="emp-header">
      <i class="fas fa-envelope emp-header-icon"></i>
      <span class="emp-title" id="emp-title">Add a recovery email</span>
    </div>
    <p class="emp-body">It looks like you don't have a recovery email address on file. If you ever forget your username or password, we can help. Please enter your email address below to continue using the ORK.</p>
    <div class="emp-field">
      <label for="emp-email">Email address</label>
      <input type="email" id="emp-email" name="emp-email" placeholder="you@example.com" autocomplete="email">
      <div class="emp-suggestion" id="emp-suggestion" role="alert">
        <i class="fas fa-magic"></i>
        <span class="emp-suggestion-text">Did you mean <strong id="emp-suggestion-val"></strong>?</span>
        <button type="button" class="emp-suggestion-use" id="emp-suggestion-use">Use it</button>
        <button type="button" class="emp-suggestion-dismiss" id="emp-suggestion-dismiss" aria-label="Dismiss">&times;</button>
      </div>
      <div class="emp-error" id="emp-error"></div>
    </div>
    <div class="emp-actions">
      <button class="emp-skip" id="emp-skip" type="button">Skip for now</button>
      <button class="emp-save" id="emp-save" type="button">Save email</button>
    </div>
  </div>
</div>
<script>
(function() {
  var SKIP_KEY = 'emp_skipped';
  if (sessionStorage.getItem(SKIP_KEY)) return;

  var overlay    = document.getElementById('emp-overlay');
  var input      = document.getElementById('emp-email');
  var saveBtn    = document.getElementById('emp-save');
  var skipBtn    = document.getElementById('emp-skip');
  var errEl      = document.getElementById('emp-error');
  var suggBox    = document.getElementById('emp-suggestion');
  var suggVal    = document.getElementById('emp-suggestion-val');
  var suggUse    = document.getElementById('emp-suggestion-use');
  var suggDismiss = document.getElementById('emp-suggestion-dismiss');

  function open()  { overlay.classList.add('emp-open'); setTimeout(function(){ input.focus(); }, 50); }
  function close() { overlay.classList.remove('emp-open'); }
  function showErr(msg) { errEl.textContent = msg; errEl.style.display = 'block'; }
  function clearErr()   { errEl.style.display = 'none'; }
  function hideSugg()   { suggBox.classList.remove('emp-suggestion-visible'); }

  setTimeout(open, 400);

  overlay.addEventListener('click', function(e) { if (e.target === overlay) { sessionStorage.setItem(SKIP_KEY, '1'); close(); } });
  skipBtn.addEventListener('click', function() { sessionStorage.setItem(SKIP_KEY, '1'); close(); });

  saveBtn.addEventListener('click', function() {
    clearErr();
    var email = (input.value || '').trim();
    if (!email) { showErr('Please enter your email address.'); input.focus(); return; }
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';
    var fd = new FormData();
    fd.append('email', email);
    fetch('<?= UIR ?>PlayerAjax/save_my_email', { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status === 0) {
          close();
        } else {
          showErr(data.error || 'Something went wrong. Please try again.');
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save email';
        }
      })
      .catch(function() {
        showErr('Network error. Please try again.');
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save email';
      });
  });

  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') saveBtn.click(); });

  // Spell-checker: runs on blur; self-contained, no dependency on revised.js
  function runSpellCheck() {
    if (typeof window.EmailSpellChecker === 'undefined') return;
    var val = (input.value || '').trim();
    if (!val) { hideSugg(); return; }
    var result = window.EmailSpellChecker.run({ email: val });
    if (result && result.full && result.full !== val) {
      suggVal.textContent = result.full;
      suggBox.classList.add('emp-suggestion-visible');
    } else {
      hideSugg();
    }
  }
  input.addEventListener('blur', runSpellCheck);
  suggUse.addEventListener('click', function() {
    input.value = suggVal.textContent;
    hideSugg();
    input.dispatchEvent(new Event('input', { bubbles: true }));
  });
  suggDismiss.addEventListener('click', hideSugg);

  // Load the spell-checker bundle (tiny, ~6.6 KB) once the modal is open
  if (typeof window.EmailSpellChecker === 'undefined') {
    var sc = document.createElement('script');
    sc.src = '<?= HTTP_TEMPLATE ?>revised-frontend/script/email-spell-checker.min.js';
    document.head.appendChild(sc);
  }
})();
</script>
<?php endif; ?>

