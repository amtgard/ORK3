{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "timeout": 120,
    "source": {
        "directories": [
            "system/lib/ork3"
        ]
    },
    "logs": {
        "text": "build/infection-t13.log",
        "summary": "build/infection-t13-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 13,
    "minCoveredMsi": 13,
    "testFramework": "phpunit",
    "bootstrap": "tests/bootstrap.php",
    "phpUnit": {
        "configDir": "."
    },
    "tmpDir": "build/infection-t13"
}
