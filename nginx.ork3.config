server {
    listen 80;
    server_name _;

    root /var/www/ork.amtgard.com;
    index index.htm index.html index.php;

    add_header Access-Control-Allow-Origin *;

    # Trust Cloudflare proxies and use CF-Connecting-IP as the client IP.
    # IP ranges from https://www.cloudflare.com/ips/ — refresh occasionally.
    # Docker bridge range covers the host-side reverse proxy that fronts this container.
    set_real_ip_from 172.16.0.0/12;
    set_real_ip_from 173.245.48.0/20;
    set_real_ip_from 103.21.244.0/22;
    set_real_ip_from 103.22.200.0/22;
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 141.101.64.0/18;
    set_real_ip_from 108.162.192.0/18;
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 188.114.96.0/20;
    set_real_ip_from 197.234.240.0/22;
    set_real_ip_from 198.41.128.0/17;
    set_real_ip_from 162.158.0.0/15;
    set_real_ip_from 104.16.0.0/13;
    set_real_ip_from 104.24.0.0/14;
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 131.0.72.0/22;
    set_real_ip_from 2400:cb00::/32;
    set_real_ip_from 2606:4700::/32;
    set_real_ip_from 2803:f800::/32;
    set_real_ip_from 2405:b500::/32;
    set_real_ip_from 2405:8100::/32;
    set_real_ip_from 2a06:98c0::/29;
    set_real_ip_from 2c0f:f248::/32;
    real_ip_header CF-Connecting-IP;
    real_ip_recursive on;

    # CMS Multi-Site pretty URLs: /k/{slug} (kingdom) and /p/{slug} (park) -> the
    # Site controller (internal rewrite; the browser URL stays pretty). Order
    # matters — the literal /blog and /post/ forms must precede the generic page
    # form, and the multi-segment {a}/{b}/... page form must come LAST so it does
    # not swallow blog/post. The replacement carries ?Route=..., so nginx appends
    # any original query args (e.g. ?p=2) automatically. Each block passes a
    # &_pfx=k|p hint so Controller_Site can enforce the /k vs /p namespace (a park
    # site is only reachable under /p/, a kingdom under /k/) even though slugs
    # share one global pool. The raw Site/view|page|blog|post routes still work
    # without these blocks (belt-and-suspenders).
    #
    # C13: the page form is multi-segment ((.+) after the site slug) so nested
    # pages /k/{slug}/{parent}/{child} route to Site/page/{slug}/{parent}/{child};
    # the dispatcher re-joins segments 3+ and Controller_Site resolves the nested
    # slug path. A single-segment page still works (the same rule matches).
    location ^~ /k/ {
        rewrite ^/k/([^/]+)/blog/?$              /orkui/index.php?Route=Site/blog/$1&_pfx=k  last;
        rewrite ^/k/([^/]+)/rss/?$               /orkui/index.php?Route=Site/rss/$1&_pfx=k  last;
        rewrite ^/k/([^/]+)/post/([^/]+)/?$      /orkui/index.php?Route=Site/post/$1/$2&_pfx=k  last;
        rewrite ^/k/([^/]+)/?$                   /orkui/index.php?Route=Site/view/$1&_pfx=k  last;
        rewrite ^/k/([^/]+)/(.+?)/?$             /orkui/index.php?Route=Site/page/$1/$2&_pfx=k  last;
        return 404;
    }

    location ^~ /p/ {
        rewrite ^/p/([^/]+)/blog/?$              /orkui/index.php?Route=Site/blog/$1&_pfx=p  last;
        rewrite ^/p/([^/]+)/rss/?$               /orkui/index.php?Route=Site/rss/$1&_pfx=p  last;
        rewrite ^/p/([^/]+)/post/([^/]+)/?$      /orkui/index.php?Route=Site/post/$1/$2&_pfx=p  last;
        rewrite ^/p/([^/]+)/?$                   /orkui/index.php?Route=Site/view/$1&_pfx=p  last;
        rewrite ^/p/([^/]+)/(.+?)/?$             /orkui/index.php?Route=Site/page/$1/$2&_pfx=p  last;
        return 404;
    }

    location / {
	try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
    }

    # Content-addressed CMS rendition media (org-site / front-door images).
    # Files under assets/cms-media/ are written under an opaque per-upload random
    # base name (bin2hex(random_bytes(16)); class.CmsMedia.php) and are NEVER
    # overwritten — a re-upload mints a NEW filename + row. So every cms-media URL
    # is effectively immutable: safe to serve with a 1-year max-age + immutable so
    # browsers AND the Cloudflare CDN fronting the /k/ and /p/ org sites stop
    # revalidating them (today they force a revalidation every 5 minutes on
    # image-heavy public pages). `public` + ACAO make them fully CDN/cross-origin
    # cacheable; Vary: Accept-Encoding is the CDN-friendly encoding-negotiation
    # signal (each URL is otherwise a single fixed object, so we deliberately do
    # NOT Vary on Accept — the extension is already in the URL). A location's
    # add_header cancels inheritance of the server-level Access-Control-Allow-Origin,
    # so it is re-stated here. `^~` gives this prefix priority over the generic
    # image regex below. NOTE: this is a STATIC-asset header only — the /k/ and /p/
    # HTML responses stay UNcached (no fastcgi_cache) so PHP still runs on every
    # pageview (public-view analytics must not be bypassed).
    location ^~ /assets/cms-media/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        add_header Vary "Accept-Encoding";
        add_header Access-Control-Allow-Origin *;
        try_files $uri =404;
    }

    # Generic raster images: heraldry crests, player avatars, app imagery. These
    # are NOT content-addressed — heraldry/player files are named by entity id
    # (e.g. assets/heraldry/kingdom/0004.png) and OVERWRITTEN in place on re-upload
    # (class.Heraldry.php / common.php). They cache-bust via a ?v=filemtime query,
    # which nginx cannot see when it matches by path — so they must NOT be marked
    # immutable (that would pin a stale crest). Keep the short, revalidating TTL: a
    # 304 is cheap and guarantees a re-uploaded crest is picked up even from an
    # unversioned reference. `webp` is included so rendition WebP (once the
    # high-res-images pipeline merges) gets a header instead of falling through
    # uncached; cms-media WebP is already handled by the immutable prefix above.
    location ~* \.(jpg|gif|png|webp) {
        add_header Cache-Control "public, max-age=300, must-revalidate";
    }

    # App JS/CSS: orkui.css carries a ?v=filemtime version param, but orkui.js is
    # referenced WITHOUT any version param (default.theme), i.e. genuinely mutable
    # at a stable URL. Neither is content-hashed, and nginx matches by path (the
    # query is invisible here), so both must stay on a short, revalidating TTL — an
    # immutable header would pin stale app code/styles until the browser cache aged
    # out. Left intentionally on max-age=300 must-revalidate.
    location ~* orkui.js {
        add_header Cache-Control "public, max-age=300, must-revalidate";
    }
    location ~* orkui.css {
        add_header Cache-Control "public, max-age=300, must-revalidate";
    }

    location = /fpm-status {
        allow 127.0.0.1;
        deny all;
        access_log off;
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $fastcgi_script_name;
        include fastcgi_params;
    }
}