#!/usr/bin/env bash
# Enforce known local-docker login passwords for fuzzy / Playwright / manual smoke.
#
# Sandbox (ork_test @ 19307):
#   megiddo / test-db-player
#   admin   / password
# Mirror (ork @ 19306):
#   admin   / password
#
# Usage:
#   bin/seed-test-credentials                  # both targets (default)
#   bin/seed-test-credentials --target sandbox
#   bin/seed-test-credentials --target mirror
#
# Also runs automatically at the end of `bin/ork-db deploy-sandbox` (sandbox only).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
exec php "${ROOT}/tools/ork-db/cli.php" seed-test-credentials "$@"
