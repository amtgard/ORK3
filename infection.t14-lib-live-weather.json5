{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "timeout": 120,
    "source": {
        "directories": [
            "system/lib/ork3"
        ]
    },
    "logs": {
        "text": "build/infection-t14-live-weather.log",
        "summary": "build/infection-t14-live-weather-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 15,
    "minCoveredMsi": 15,
    "testFramework": "phpunit",
    "bootstrap": "tests/bootstrap.php",
    "phpUnit": {
        "configDir": "."
    },
    "tmpDir": "build/infection-t14-live-weather"
}
