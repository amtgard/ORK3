{
  "defaults": {
    "viewport": { "width": 1280, "height": 720 },
    "repeat": 5,
    "waitAfterMs": 500,
    "auth": "none"
  },
  "pages": [
    {
      "id": "home-anonymous",
      "url": "./index.php?Route=",
      "auth": "none",
      "readySelector": "body",
      "notes": "rsvp.spec.ts — public home / event search widget"
    },
    {
      "id": "home-authenticated",
      "url": "./index.php?Route=",
      "auth": "login",
      "readySelector": "#main, body",
      "notes": "infrastructure.spec.ts — post-login home"
    },
    {
      "id": "player-profile",
      "url": "./index.php?Route=Player/profile",
      "auth": "login",
      "waitAfterMs": 1000,
      "notes": "rsvp.spec.ts — logged-in player profile (default route)"
    },
    {
      "id": "player-profile-sandbox",
      "url": "./index.php?Route=Player/profile/1",
      "auth": "login",
      "waitAfterMs": 1000,
      "notes": "player-profile.spec.ts — sandbox player id 1"
    },
    {
      "id": "park-profile",
      "url": "./index.php?Route=Park/profile/1",
      "auth": "login",
      "notes": "park-profile.spec.ts / banner.spec.ts"
    },
    {
      "id": "kingdom-profile",
      "url": "./index.php?Route=Kingdom/profile/1",
      "auth": "login",
      "notes": "kingdom-profile.spec.ts / banner.spec.ts"
    },
    {
      "id": "event-list",
      "url": "./index.php?Route=Event",
      "auth": "login",
      "notes": "event-planning.spec.ts / banner.spec.ts"
    },
    {
      "id": "event-detail",
      "url": "./index.php?Route=Event/detail/1/1",
