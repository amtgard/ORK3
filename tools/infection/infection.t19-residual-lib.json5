// T-19 residual lib bypass — milestone-scoped Infection config (DS-19 §2.3).
// Run each R-19 hop pass with matching --filter and --test-framework-options; see ds-19-residual-lib-discovery.md.
{
    "$schema": "../../vendor/infection/infection/resources/schema.json",
    "timeout": 120,
    "source": {
        "directories": [
            "system/lib/ork3"
        ]
    },
    "logs": {
        "text": "build/infection-t19.log",
        "summary": "build/infection-t19-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 15,
    "minCoveredMsi": 15,
    "testFramework": "phpunit",
    "bootstrap": "tests/bootstrap.php",
    "phpUnit": {
        "configDir": "."
    },
    "tmpDir": "build/infection-t19"
}
