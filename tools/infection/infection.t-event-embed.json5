// RB-N EventEmbed domain — scoped Infection for class.EventEmbed.php.
// Run: sh bin/run-infection.sh --configuration=tools/infection/infection.t-event-embed.json5 --filter=class.EventEmbed.php
{
    "$schema": "../../vendor/infection/infection/resources/schema.json",
    "timeout": 120,
    "source": {
        "directories": [
            "system/lib/ork3"
        ]
    },
    "logs": {
        "text": "build/infection-t-event-embed.log",
        "summary": "build/infection-t-event-embed-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 15,
    "minCoveredMsi": 15,
    "testFramework": "phpunit",
    "bootstrap": "tests/bootstrap.php",
    "phpUnit": {
        "configDir": "../.."
    },
    "tmpDir": "build/infection-t-event-embed"
}
