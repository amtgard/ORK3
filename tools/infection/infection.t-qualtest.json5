// RB-N QualTest domain — scoped Infection config for class.QualTest.php.
// Run: sh bin/run-infection.sh --configuration=tools/infection/infection.t-qualtest.json5 --filter=class.QualTest.php
{
    "$schema": "../../vendor/infection/infection/resources/schema.json",
    "timeout": 120,
    "source": {
        "directories": [
            "system/lib/ork3"
        ]
    },
    "logs": {
        "text": "build/infection-t-qualtest.log",
        "summary": "build/infection-t-qualtest-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 15,
    "minCoveredMsi": 15,
    "testFramework": "phpunit",
    "bootstrap": "tests/bootstrap.php",
    "phpUnit": {
        "configDir": "../.."
    },
    "tmpDir": "build/infection-t-qualtest"
}
